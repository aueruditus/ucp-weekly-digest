# Required API keys
ANTHROPIC_API_KEY=sk-ant-...
WONDERCRAFT_API_KEY=wc-...

# GitHub token for fetching UCP org activity.
# Local: a PAT with `public_repo` scope (public repos work unauthenticated,
#   but you'll hit a 60/hr rate limit fast).
# CI: GitHub Actions provides ${{ secrets.GITHUB_TOKEN }} automatically —
#   the workflow already wires this into GH_FETCH_TOKEN, no setup needed.
GH_FETCH_TOKEN=ghp_...

# Database (self-hosted Supabase via SSH tunnel)
DATABASE_URL=postgresql://postgres:postgres@localhost:54322/postgres

# Netlify deploy
NETLIFY_AUTH_TOKEN=
NETLIFY_SITE_ID=
NETLIFY_SITE_URL=https://ucp-weekly-digest.netlify.app

# Pipeline config
PIPELINE_ENVIRONMENT=local
CLAUDE_MODEL=claude-sonnet-4-5-20250929
